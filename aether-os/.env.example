# Aether OS — environment variables

# ── GitHub Models (Copilot Pro — all premium models, high rate limits) ─────────
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)" — no special scopes needed
# 3. Paste your token below
GITHUB_TOKEN=your_github_token_here

# With Copilot Pro you can use ANY of these models via --provider github:
#   GPT:     gpt-4o, gpt-4o-mini, o1, o1-mini, o3-mini
#   Claude:  claude-3-7-sonnet, claude-3-5-sonnet, claude-3-5-haiku
#   Gemini:  gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro
#   Llama:   Meta-Llama-3.1-405B-Instruct, Meta-Llama-3.1-70B-Instruct
#   Phi:     Phi-4, Phi-3.5-MoE-instruct
#   Mistral: Mistral-large-2411, Mistral-small
#   Other:   DeepSeek-V3, DeepSeek-R1, Cohere-command-r-plus-08-2024
#
# Example: python main.py --provider github --model claude-3-5-sonnet

# ── Direct API keys (optional — only needed if not using GitHub Models) ──────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
HF_API_KEY=your_huggingface_token_here

# Ollama runs locally — no key needed.
# Start it with: ollama serve
