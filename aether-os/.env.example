# AetheerAI — An AI Master!!  (by Tecbunny)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments and are ignored.
# You only need the variables for the tools / providers you actually use.
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1 — AI PROVIDER KEYS
# ═══════════════════════════════════════════════════════════════════════════════

# ── GitHub Models (Copilot Pro — all premium models, high rate limits) ────────
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)" — no special scopes needed for inference
# 3. Paste your token below
GITHUB_TOKEN=your_github_token_here

# Supported models via GitHub provider:
#   GPT:     gpt-4o, gpt-4o-mini, gpt-4.1, o1, o1-mini, o3-mini
#   Claude:  claude-3-7-sonnet, claude-3-5-sonnet, claude-3-5-haiku
#   Gemini:  gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro
#   Llama:   Meta-Llama-3.1-405B-Instruct, Meta-Llama-3.1-70B-Instruct
#   Phi:     Phi-4, Phi-3.5-MoE-instruct
#   Mistral: Mistral-large-2411, Mistral-small
#   Other:   DeepSeek-V3, DeepSeek-R1, Cohere-command-r-plus-08-2024

# ── Direct API keys (optional — only needed if not using GitHub Models) ───────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
HF_API_KEY=your_huggingface_token_here

# ── Stability AI (image generation — alternative to DALL-E) ──────────────────
# Get your key at https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_ai_key_here

# Ollama runs fully locally — no key needed.
# Start it with: ollama serve


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2 — ENTERPRISE TOOL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# ── github_tool — GitHub repository management ────────────────────────────────
# Token: needs repo + pull_request scopes for write actions
# GITHUB_TOKEN is already set above (shared with GitHub Models provider)
# Default repo to operate on (owner/repo format, e.g. acme/my-app):
GITHUB_REPO=your_org/your_repo

# ── sql_db_tool — Database access ────────────────────────────────────────────
# SQLAlchemy connection URL.  Examples:
#   PostgreSQL : postgresql://user:password@host:5432/dbname
#   MySQL      : mysql+pymysql://user:password@host:3306/dbname
#   SQLite     : sqlite:///./data/mydb.sqlite
#   MSSQL      : mssql+pyodbc://user:password@host/dbname?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=sqlite:///./data/aether.sqlite

# ── email_tool — Send and read email ─────────────────────────────────────────
# Gmail tip: use an App Password (16-char), not your regular password.
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_email_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── slack_discord_tool — Team notifications ───────────────────────────────────
# Slack: create an Incoming Webhook at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# ── aws_gcp_tool — Amazon Web Services ───────────────────────────────────────
# Create an IAM user with programmatic access. Minimum permissions:
#   S3:  s3:ListBucket, s3:GetObject, s3:PutObject, s3:DeleteObject
#   EC2: ec2:DescribeInstances, ec2:StartInstances, ec2:StopInstances, ec2:RebootInstances
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ── aws_gcp_tool — Google Cloud Platform ─────────────────────────────────────
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key and set the path below.
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your/gcp-service-account-key.json
GCP_PROJECT_ID=your-gcp-project-id

# ── kubernetes_tool — Kubernetes cluster management ────────────────────────────
# Path to your kubeconfig file (default ~/.kube/config is used automatically
# when KUBECONFIG is not set).  For in-cluster usage leave this unset.
KUBECONFIG=C:/Users/YourName/.kube/config


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3 — OPTIONAL / ADVANCED
# ═══════════════════════════════════════════════════════════════════════════════

# Custom Ollama endpoint (defaults to http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Override the agent output directory (defaults to aether-os/agent_output/)
# AGENT_OUTPUT_DIR=C:/custom/output/path
