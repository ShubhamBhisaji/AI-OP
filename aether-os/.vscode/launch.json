{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Aether OS — CLI (GitHub Models — FREE)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--provider", "github"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Aether OS — Claude Sonnet 4.6 (1x)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--provider", "github", "--model", "claude-sonnet-4-6"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "envFile": "${workspaceFolder}/.env"
    },
