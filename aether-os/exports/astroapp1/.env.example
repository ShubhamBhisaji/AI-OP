# Aether OS — environment variables

# ── GitHub Models (Copilot Pro — your available models) ──────────────────
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)" — no special scopes needed
# 3. Paste your token below
GITHUB_TOKEN=your_value_here

# Your Copilot Pro models (from VS Code model picker):
#   claude-sonnet-4-6     (1x)  ← default, best balance
#   claude-opus-4-6       (3x)  most powerful
#   claude-haiku-4-5      (0.33x) fastest, cheapest
#   claude-opus-4-5       (3x)
#   claude-sonnet-4       (1x)
#   gemini-3-pro          (1x)  [Preview, deprecates 2026-03-26]
#   gpt-5.4               (1x)
#   gpt-5.3-codex         (1x)
#
# Example: python main.py --provider github --model claude-opus-4-6

# ── Direct API keys (optional) ────────────────────────────────────
OPENAI_API_KEY=your_value_here
ANTHROPIC_API_KEY=your_value_here
GEMINI_API_KEY=your_value_here
HF_API_KEY=your_value_here

# Ollama runs locally — no key needed.
# Start it with: ollama serve