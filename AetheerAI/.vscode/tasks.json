{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AETHEERAI: Run CLI (GitHub Models — FREE)",
      "type": "shell",
      "command": "python",
      "args": ["main.py", "--provider", "github"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "AETHEERAI: Run CLI (OpenAI)",
      "type": "shell",
      "command": "python",
