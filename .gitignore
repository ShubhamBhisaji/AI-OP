# Build outputs – never commit large binaries
output/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Secrets / keys
.env
*.key
*.pem

# Runtime / generated data
logs/
*.log
AetheerAI/memory/chroma_store/
*.sqlite3

# data/ — processed and exported artefacts (too large / ephemeral)
data/processed/
data/exports/

# models/ — large binary files (use Git LFS or external registry)
models/trained/
models/checkpoints/

# src-layout build artefacts
src/*.egg-info/
dist/
build/
